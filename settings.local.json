{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^/deep-research",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/preflight_check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pre_write_check.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_write_check.py"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_task_log.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/final_quality_gate.py"
          }
        ]
      }
    ]
  }
}
