# ══════════════════════════════════════════════════════════════════
# Prisma research flow v1 · 环境变量配置
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
# LLM 规划/查询生成层 —— 
# ──────────────────────────────────────────────────────────────────
# 原因:GLM 对政治敏感话题内容审查严格,中转支持的
# Gemini 2.5 Pro / Grok-4 / DeepSeek-V3.2 / GPT-5 都更宽容
#
# Planner (生成研究计划):推荐 Gemini 2.5 Pro (长上下文、架构能力强)
#   备选:grok-4(跨议题宽容)、deepseek-v3.2-exp(省钱)、gpt-5(稳定)
#
# Query-gen (生成搜索查询):推荐 DeepSeek (便宜、中文强)
#   备选:gemini-2.5-flash(快)
# ──────────────────────────────────────────────────────────────────

PLANNER_API_KEY=
PLANNER_API_KEY_BACKUP=          # 402 自动切换到此 Key
PLANNER_BASE_URL=
PLANNER_MODEL=gemini-2.5-flash

QUERY_API_KEY=
QUERY_API_KEY_BACKUP=            # 402 自动切换到此 Key
QUERY_BASE_URL=
QUERY_MODEL=deepseek-v3.2-exp

# ──────────────────────────────────────────────────────────────────
# Claude API —— Claude Code 主进程 + 所有 subagent
# 如走 xinghuapi 中转,Claude Code 会自动读取这两个变量
# ──────────────────────────────────────────────────────────────────

ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_BACKUP=        # 402 时手动替换 ANTHROPIC_API_KEY 后重启 claude

# ──────────────────────────────────────────────────────────────────
# Tavily 搜索 —— 最多 8 个 Key 熔断轮询(v3 扩容)
# 用户配置 8 个后,阶段 2 可并发 spawn 多达 8 个 researcher × 每个 5 次查询
# 前面 Key 失效(401/403/429)自动切下一个
# ──────────────────────────────────────────────────────────────────

TAVILY_API_KEY_1=
TAVILY_API_KEY_2=
TAVILY_API_KEY_3=
TAVILY_API_KEY_4=
TAVILY_API_KEY_5=
TAVILY_API_KEY_6=
TAVILY_API_KEY_7=
TAVILY_API_KEY_8=

# ──────────────────────────────────────────────────────────────────
# UTF-8 强制 —— 根治 Windows GBK 编码问题(v3 新增)
# 这些变量由脚本自动 set,但保留在 .env 里以防万一
# ──────────────────────────────────────────────────────────────────

PYTHONIOENCODING=utf-8
PYTHONUTF8=1
